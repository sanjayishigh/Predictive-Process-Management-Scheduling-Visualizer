{
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/app.py"
    },
    {
      "source": "/fcfs",
      "destination": "/frontend/fcfs.html"
    },
    {
      "source": "/sjf",
      "destination": "/frontend/sjf.html"
    },
    {
      "source": "/roundrobin",
      "destination": "/frontend/roundrobin.html"
    },
    {
      "source": "/ai_scheduler",
      "destination": "/frontend/ai_scheduler.html"
    },
    {
      "source": "/compare",
      "destination": "/frontend/compare.html"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
